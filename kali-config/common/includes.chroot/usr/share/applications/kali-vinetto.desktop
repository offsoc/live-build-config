[Desktop Entry]
Name=vinetto
Comment=Extract thumbnails and associated metadata from Thumbs.db files
Encoding=UTF-8
Exec=/usr/share/kali-menu/exec-in-shell "vinetto -h"
Icon=kali-menu
StartupNotify=false
Terminal=true
Type=Application
Categories=11-04-forensic-analysis-tools;
X-Kali-Package=vinetto
