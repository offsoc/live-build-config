[Desktop Entry]
Name=gobuster
Comment=Directory/File, DNS and VHost busting tool
Encoding=UTF-8
Exec=/usr/share/kali-menu/exec-in-shell "gobuster -h"
Icon=kali-gobuster
StartupNotify=false
Terminal=true
Type=Application
Categories=03-04-web-crawlers;
X-Kali-Package=gobuster
StartupWMClass=com-sittinglittleduck-gobuster-Start
